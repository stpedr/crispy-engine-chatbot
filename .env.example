NODE_ENV=development
PORT=3000
SERVICE_NAME=sales-bot
LOG_LEVEL=info
LOG_PRETTY=true
METRICS_ENABLED=true
DATA_FILE=.data/sales-bot.json
HANDOFF_MAX_ATTEMPTS=3
HANDOFF_RETRY_DELAY_MS=100
OUTBOUND_TIMEOUT_MS=5000

# Webhooks normalizados de WhatsApp/Instagram.
WEBHOOK_VERIFY_TOKEN=
WEBHOOK_INGRESS_TOKEN=

# Opcional: sincronize handoffs com um CRM via HTTP.
CRM_WEBHOOK_URL=
CRM_TOKEN=

# Opcional: gere respostas por um servico HTTP; templates sao o fallback.
COPY_GENERATOR_URL=
COPY_GENERATOR_TOKEN=

# Opcional: envie traces para um collector OTLP HTTP.
# Exemplo: http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
